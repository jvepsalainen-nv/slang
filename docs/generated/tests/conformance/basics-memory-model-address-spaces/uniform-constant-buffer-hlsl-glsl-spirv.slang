// Per-target fan-out (GLSL, SPIRV) of uniform-constant-buffer-hlsl.slang. The `ConstantBuffer<T>`
// that HLSL emits as a `cbuffer` on a `b` register also maps to a GLSL `uniform` block and a SPIRV
// `OpVariable` in the `Uniform` storage class; CHECK pins each target's uniform-buffer form.

//TEST:SIMPLE(filecheck=GLSL):-target glsl -entry computeMain -stage compute
//TEST:SIMPLE(filecheck=SPV):-target spirv-asm -entry computeMain -stage compute

struct Params {
    float scale;
    int   offset;
};

ConstantBuffer<Params> cb;

[numthreads(1, 1, 1)]
void computeMain(uint3 tid : SV_DispatchThreadID, RWStructuredBuffer<float> output)
{
    output[0] = cb.scale + float(cb.offset);
}

// GLSL emits ConstantBuffer as a uniform block.
// GLSL: uniform block_
// SPIRV emits ConstantBuffer as an OpVariable in the Uniform storage class.
// SPV: OpVariable {{.*}} Uniform
